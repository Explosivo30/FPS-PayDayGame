        private void DrawGeneralProperties()
        {
            if (dungeonData == null)
            {
                EditorGUILayout.HelpBox("No dungeon data selected", MessageType.Info);
                return;
            }
            
            EditorGUILayout.LabelField("General Settings", EditorStyles.boldLabel);
            EditorGUILayout.Space();
            
            float newCellSize = EditorGUILayout.Slider("Cell Size:", dungeonData.gridCellSize, 1f, 20f);
            if (newCellSize != dungeonData.gridCellSize)
            {
                dungeonData.gridCellSize = newCellSize;
                EditorUtility.SetDirty(dungeonData);
            }
            
            float newHeightPerLevel = EditorGUILayout.FloatField("Height Per Level (m):", dungeonData.heightPerLevel);
            if (newHeightPerLevel != dungeonData.heightPerLevel)
            {
                dungeonData.heightPerLevel = newHeightPerLevel;
                EditorUtility.SetDirty(dungeonData);
            }
            
            int newTunnelSegments = EditorGUILayout.IntSlider("Tunnel Segments:", dungeonData.tunnelSegments, 4, 16);
            if (newTunnelSegments != dungeonData.tunnelSegments)
            {
                dungeonData.tunnelSegments = newTunnelSegments;
                EditorUtility.SetDirty(dungeonData);
            }
            
            float newTunnelHeight = EditorGUILayout.FloatField("Tunnel Height (m):", dungeonData.defaultTunnelHeight);
            if (newTunnelHeight != dungeonData.defaultTunnelHeight)
            {
                dungeonData.defaultTunnelHeight = newTunnelHeight;
                EditorUtility.SetDirty(dungeonData);
            }
            
            EditorGUILayout.Space();
            EditorGUILayout.LabelField("Mesh Replacement (Optional)", EditorStyles.boldLabel);
            EditorGUILayout.HelpBox("Mesh Replacement Set es opcional. Si no lo asignas, el generador usará primitivas de Unity (cubos).", MessageType.Info);
            
            MeshReplacementSet newMeshSet = (MeshReplacementSet)EditorGUILayout.ObjectField(
                "Mesh Set:", 
                dungeonData.meshSet, 
                typeof(MeshReplacementSet), 
                false
            );
            
            if (newMeshSet != dungeonData.meshSet)
            {
                dungeonData.meshSet = newMeshSet;
                EditorUtility.SetDirty(dungeonData);
            }
            
            EditorGUILayout.Space();
            EditorGUILayout.LabelField("Statistics", EditorStyles.boldLabel);
            EditorGUILayout.LabelField("Nodes:", dungeonData.nodes != null ? dungeonData.nodes.Count.ToString() : "0");
            EditorGUILayout.LabelField("Connections:", dungeonData.connections != null ? dungeonData.connections.Count.ToString() : "0");
            EditorGUILayout.LabelField("Rooms:", dungeonData.rooms != null ? dungeonData.rooms.Count.ToString() : "0");
            
            if (currentMode == ToolMode.DefineRoomNumeric)
            {
                EditorGUILayout.Space();
                EditorGUILayout.LabelField("Numeric Room Definition", EditorStyles.boldLabel);
                
                roomSizeNumeric = EditorGUILayout.Vector2IntField("Size:", roomSizeNumeric);
                roomPositionNumeric = EditorGUILayout.Vector2IntField("Position:", roomPositionNumeric);
                
                if (GUILayout.Button("Create Room"))
                {
                    CreateNumericRoom();
                }
            }
        }
        #endregion

        #region Helper Methods
        private Vector2 GridToScreen(Vector2Int gridPos, Rect canvasRect)
        {
            float cellSize = dungeonData.gridCellSize * gridZoom;
            return new Vector2(
                canvasRect.x + gridPos.x * cellSize + gridOffset.x,
                canvasRect.y + gridPos.y * cellSize + gridOffset.y
            );
        }

        private Vector2Int ScreenToGrid(Vector2 screenPos, Rect canvasRect)
        {
            float cellSize = dungeonData.gridCellSize * gridZoom;
            return new Vector2Int(
                Mathf.RoundToInt((screenPos.x - canvasRect.x - gridOffset.x) / cellSize),
                Mathf.RoundToInt((screenPos.y - canvasRect.y - gridOffset.y) / cellSize)
            );
        }

        private Rect GetCellScreenRect(Vector2Int gridPos, Rect canvasRect)
        {
            float cellSize = dungeonData.gridCellSize * gridZoom;
            Vector2 screenPos = GridToScreen(gridPos, canvasRect);
            return new Rect(screenPos.x, screenPos.y, cellSize, cellSize);
        }

        private DungeonNode GetNodeAtPosition(Vector2Int gridPos, int heightLevel)
        {
            return dungeonData.nodes.Find(n => n.gridPosition == gridPos && n.heightLevel == heightLevel);
        }

        private DungeonRoom GetRoomAtPosition(Vector2Int gridPos, int heightLevel)
        {
            return dungeonData.rooms.Find(r => r.gridCells.Contains(gridPos) && r.heightLevel == heightLevel);
        }

        private void CreateConnection(DungeonNode nodeA, DungeonNode nodeB)
        {
            // Check if connection already exists
            bool exists = dungeonData.connections.Exists(c =>
                (c.nodeAId == nodeA.id && c.nodeBId == nodeB.id) ||
                (c.nodeAId == nodeB.id && c.nodeBId == nodeA.id)
            );
            
            if (!exists)
            {
                DungeonConnection newConnection = new DungeonConnection(nodeA.id, nodeB.id, currentCorridorWidth);
                newConnection.transitionType = currentConnectionType;
                
                // Auto-detect if height difference requires special transition
                if (nodeA.heightLevel != nodeB.heightLevel && newConnection.transitionType == ConnectionType.Flat)
                {
                    newConnection.transitionType = ConnectionType.Ramp;
                }
                
                dungeonData.connections.Add(newConnection);
                EditorUtility.SetDirty(dungeonData);
            }
        }

        private void DeleteNode(DungeonNode node)
        {
            // Remove all connections to this node
            dungeonData.connections.RemoveAll(c => c.nodeAId == node.id || c.nodeBId == node.id);
            
            // Remove the node
            dungeonData.nodes.Remove(node);
            dungeonData.RebuildCache();
            
            EditorUtility.SetDirty(dungeonData);
        }

        private void CreateNumericRoom()
        {
            if (dungeonData == null) return;
            
            DungeonRoom newRoom = new DungeonRoom(currentHeightLevel);
            newRoom.roomName = "Room_" + (dungeonData.rooms.Count + 1);
            newRoom.manualSize = roomSizeNumeric;
            newRoom.shape = RoomShape.Rectangular;
            
            for (int x = 0; x < roomSizeNumeric.x; x++)
            {
                for (int y = 0; y < roomSizeNumeric.y; y++)
                {
                    newRoom.gridCells.Add(roomPositionNumeric + new Vector2Int(x, y));
                }
            }
            
            dungeonData.rooms.Add(newRoom);
            EditorUtility.SetDirty(dungeonData);
            Repaint();
        }

        private void ClearSelection()
        {
            selectedNode = null;
            selectedConnection = null;
            selectedRoom = null;
            connectionStartNode = null;
        }

        private void CreateNewDungeonData()
        {
            string path = EditorUtility.SaveFilePanelInProject(
                "Create New Dungeon Data",
                "NewDungeon",
                "asset",
                "Choose a location to save the dungeon data"
            );
            
            if (!string.IsNullOrEmpty(path))
            {
                DungeonData newData = ScriptableObject.CreateInstance<DungeonData>();
                AssetDatabase.CreateAsset(newData, path);
                AssetDatabase.SaveAssets();
                
                dungeonData = newData;
                serializedData = new SerializedObject(dungeonData);
                
                EditorUtility.FocusProjectWindow();
                Selection.activeObject = newData;
            }
        }

        private void GenerateDungeon()
        {
            if (dungeonData == null)
            {
                EditorUtility.DisplayDialog("Error", "No dungeon data selected!", "OK");
                return;
            }
            
            // Clean up previous generation
            if (generatedDungeon != null)
            {
                if (EditorUtility.DisplayDialog("Replace Existing Dungeon?", 
                    "A dungeon already exists. Delete and regenerate?", 
                    "Yes", "Cancel"))
                {
                    DestroyImmediate(generatedDungeon);
                }
                else
                {
                    return;
                }
            }
            
            generatedDungeon = DungeonGenerator.Generate(dungeonData);
            
            if (generatedDungeon != null)
            {
                Selection.activeGameObject = generatedDungeon;
                EditorGUIUtility.PingObject(generatedDungeon);
            }
        }

        private void ReplaceMeshes()
        {
            if (generatedDungeon == null)
            {
                EditorUtility.DisplayDialog("Error", "No generated dungeon found! Generate a dungeon first.", "OK");
                return;
            }
            
            if (dungeonData == null || dungeonData.meshSet == null)
            {
                EditorUtility.DisplayDialog("Error", "No mesh replacement set assigned!", "OK");
                return;
            }
            
            DungeonMeshReplacer.ReplaceMeshes(dungeonData, generatedDungeon);
        }

        private void RestoreOriginal()
        {
            if (generatedDungeon == null)
            {
                EditorUtility.DisplayDialog("Error", "No generated dungeon found!", "OK");
                return;
            }
            
            DungeonMeshReplacer.RestoreOriginalMeshes(generatedDungeon);
        }
        #endregion
    }
}
